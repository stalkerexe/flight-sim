*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
htmlcov/
.coverage

# MyPy
.mypy_cache/

# Pytest
.pytest_cache/

# Gradle
.gradle/

# DS_Store
.DS_Store

# Thumbs
Thumbs.db
