```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so

# TypeScript/JavaScript build output
*.js.map
*.tsbuildinfo

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/

# Gradle
.gradle/

# Maven
target/

# Temporary files
*.tmp
*~
.DS_Store
Thumbs.db
```