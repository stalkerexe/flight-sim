@echo off
:: Включаем поддержку UTF-8, чтобы можно было писать коммиты на русском
chcp 65001 >nul

echo ==========================================
echo   Скрипт быстрого обновления GitHub
echo ==========================================
echo.

:: Спрашиваем сообщение для коммита
set /p commit_msg="Введите сообщение для коммита: "

:: Проверяем, что сообщение не пустое
if "%commit_msg%"=="" (
    echo Ошибка: Сообщение не может быть пустым!
    pause
    exit /b
)

echo.
echo [1/3] Добавляем файлы...
git add .

echo.
echo [2/3] Создаем коммит: "%commit_msg%"
git commit -m "%commit_msg%"

:: Проверяем, удалось ли сделать коммит (были ли вообще изменения)
if %errorlevel% neq 0 (
    echo.
    echo Нечего коммитить (нет изменений) или произошла ошибка.
    echo Пропускаем отправку на GitHub.
    pause
    exit /b
)

echo.
echo [3/3] Отправляем на GitHub...
git push

echo.
echo ==========================================
echo   Готово! Проект успешно обновлен.
echo ==========================================
pause